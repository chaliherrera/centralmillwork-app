PORT=4000
NODE_ENV=production

# PostgreSQL — Railway provides these when you add a Postgres plugin.
# Copy from Railway dashboard → Variables tab.
DB_HOST=your-railway-postgres-host.railway.internal
DB_PORT=5432
DB_NAME=railway
DB_USER=postgres
DB_PASSWORD=your-db-password
PGPASSWORD=your-db-password

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRES_IN=8h

# CORS — your Railway app public URL
CORS_ORIGIN=https://your-app.up.railway.app

# GitHub Pages — for sharing HTML reports (optional)
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_USERNAME=your-github-username
